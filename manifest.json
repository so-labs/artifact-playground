{
  "name": "Artifact Playground",
  "short_name": "ArtifactPG",
  "description": "ブラウザでもアプリでも動く、ちょっとした実験ツール集",
  "start_url": "./",
  "scope": "./",
  "display": "standalone",
  "background_color": "#2563eb",
  "theme_color": "#ffffff",
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "file_handlers": [
    {
      "action": "./",
      "accept": {
        "text/markdown": [".md", ".markdown", ".mdown"],
        "text/plain": [".txt", ".text"]
      }
    }
  ],
  "share_target": {
    "action": "./?share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "files": [
        {
          "name": "shared_file",
          "accept": [".md", ".markdown", ".mdown", ".txt", ".text", "text/markdown", "text/plain", "text/*", "application/octet-stream", "*/*"]
        }
      ]
    }
  },
  "icons": [
    {
      "src": "icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    }
  ]
}